# RJ Shop — Backend Environment Template
# Copy this file to `.env` and fill in real values. Never commit `.env`.

# MongoDB connection string
MONGO_URI=mongodb://127.0.0.1:27017/rj_shop

# Port the Express server listens on
PORT=5000

# JWT auth
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=7d

# Razorpay payment gateway (https://dashboard.razorpay.com/app/keys)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx
# Optional: secret configured for the Razorpay webhook (Settings → Webhooks)
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxxxxxxxx

# Shiprocket shipping (https://app.shiprocket.in — API user credentials)
SHIPROCKET_EMAIL=your_shiprocket_email@example.com
SHIPROCKET_PASSWORD=your_shiprocket_api_password
