{
  "expo": {
    "name": "RJ Shop",
    "slug": "rj-shop-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./src/assets/logo.png",
    "userInterfaceStyle": "light",
    "scheme": "rjshop",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#0d131b"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.rjshop.mobile"
    },
    "android": {
      "package": "com.rjshop.mobile",
      "adaptiveIcon": {
        "backgroundColor": "#0d131b"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "extra": {
      "apiUrl": "https://rj-mobile-backend.onrender.com/api",
      "eas": {
        "projectId": "8efe2136-6881-4e80-8645-51e87ae2054a"
      }
    },
    "plugins": [
      "expo-font"
    ],
    "owner": "rjstore9097"
  }
}
